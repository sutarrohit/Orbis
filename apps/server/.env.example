
PORT=4000
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"
LOG_LEVEL="silent"

# Connect to Postgres via the shared transaction-mode pooler (IPv4-only)
DATABASE_URL="postgresql://u:p@localhost:5432/db"

# Connect to Postgres via the shared session-mode pooler (used for migrations)
DIRECT_URL="postgresql://u:p@localhost:5432/db"

# Telegram channel
TELEGRAM_BOT_TOKEN=""
# Random string (>=16 chars) you generate; echoed back by Telegram on each webhook call
TELEGRAM_WEBHOOK_SECRET=""
# Public base URL Telegram posts webhooks to (e.g. an ngrok/cloudflared tunnel to :4000)
PUBLIC_URL="http://localhost:4000"

# Better Auth
# Random secret (>=16 chars); generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
# Base URL the auth server runs on
BETTER_AUTH_URL="http://localhost:4000"
# Google OAuth credentials (https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI: http://localhost:4000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Python agent service ─────────────────────────────────────────────────────
# Base URL of the FastAPI agent service Hono proxies to.
AGENTS_SERVICE_URL="http://localhost:8000"
# Shared HS256 secret for the Hono→Python service JWT. Generate with:
#   openssl rand -base64 32
# Set the SAME value as AGENTS_JWT_SECRET in packages/Agents/.env
AGENTS_JWT_SECRET=""


